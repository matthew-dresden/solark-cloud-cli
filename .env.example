# SolarkCloud CLI Configuration
# Copy this file to .env and fill in your values.
# All values can also be set as environment variables or CLI flags.
# Precedence: CLI flag > environment variable > .env file > default

# === Account Settings ===
SOLARK_USERNAME=your-email@example.com
SOLARK_PASSWORD=your-password
SOLARK_PLANT_ID=123456

# === API Settings ===
SOLARK_API_URL=https://api.solarkcloud.com
SOLARK_OUTPUT_FORMAT=table
SOLARK_TIMEOUT=30
SOLARK_LOG_LEVEL=warning

# === Rate Configuration (for --show-value) ===
#
# These example values are from DTE Energy rate plan R18 Cat1 TOD 3PM-7PM
# (Rider 18 Distributed Generation with Time-of-Day pricing) as of 2025-2026.
# Replace with your own utility's rates.
#
# Rate sources:
#   Summer rates: DTE bill dated Jul 14, 2025 (service Jun 12 - Jul 11, 2025)
#   Non-summer rates: DTE bill dated Mar 12, 2026 (service Feb 10 - Mar 11, 2026)
#     Post-MPSC rate change effective March 5, 2026

# Season boundaries (MM-DD format)
# DTE defines summer as June 1 through September 30.
SOLARK_RATE_SUMMER_START=06-01
SOLARK_RATE_SUMMER_END=09-30

# Blended average rates ($/kWh) — used for year and month value calculations.
# These are the effective all-in rates computed from actual DTE bills:
#   Summer blended inflow:  $87.39 total charges / 390.879 kWh inflow = $0.2235/kWh
#   Summer blended outflow: $141.65 total credit / 1364.273 kWh outflow = $0.1038/kWh
#   Non-summer blended inflow:  $243.61 total charges / 1071.513 kWh inflow = $0.2274/kWh
#   Non-summer blended outflow: $118.17 total credit / 1193.838 kWh outflow = $0.0990/kWh
SOLARK_RATE_SUMMER_INFLOW=0.2235
SOLARK_RATE_SUMMER_OUTFLOW=0.1038
SOLARK_RATE_NONSUMMER_INFLOW=0.2274
SOLARK_RATE_NONSUMMER_OUTFLOW=0.0990

# Time-of-use peak period definition
# DTE R18 TOD peak period is 3PM-7PM (15:00-19:00), weekdays only.
SOLARK_RATE_PEAK_START=15:00
SOLARK_RATE_PEAK_END=19:00
SOLARK_RATE_PEAK_DAYS=mon,tue,wed,thu,fri

# Granular TOU rates ($/kWh) — on-peak and off-peak by season.
# These are the per-kWh component totals from DTE bills
# (Capacity + Non-Capacity + PSCR + Distribution).
#
# Summer (from Jul 2025 bill):
#   On-Peak inflow:  $0.05649 + $0.08838 + $0.00250 + $0.08907 = $0.23644
#   Off-Peak inflow: $0.03403 + $0.05325 + $0.00250 + $0.08907 = $0.17885
#   On-Peak outflow credit:  $0.14737
#   Off-Peak outflow credit: $0.08978
SOLARK_RATE_SUMMER_PEAK_INFLOW=0.23644
SOLARK_RATE_SUMMER_OFFPEAK_INFLOW=0.17885
SOLARK_RATE_SUMMER_PEAK_OUTFLOW=0.14737
SOLARK_RATE_SUMMER_OFFPEAK_OUTFLOW=0.08978

# Non-summer (from Mar 2026 bill, post-MPSC March 5, 2026 rate change):
#   On-Peak inflow:  $0.03839 + $0.06480 + $0.01877 + $0.09726 = $0.21922
#   Off-Peak inflow: $0.03240 + $0.05469 + $0.01877 + $0.09726 = $0.20312
#   On-Peak outflow credit:  $0.12196
#   Off-Peak outflow credit: $0.10586
SOLARK_RATE_NONSUMMER_PEAK_INFLOW=0.21922
SOLARK_RATE_NONSUMMER_OFFPEAK_INFLOW=0.20312
SOLARK_RATE_NONSUMMER_PEAK_OUTFLOW=0.12196
SOLARK_RATE_NONSUMMER_OFFPEAK_OUTFLOW=0.10586
